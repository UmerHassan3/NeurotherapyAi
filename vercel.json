{
  "version": 2,
  "buildCommand": "cd neurotherapy && npm install && npm run build",
  "outputDirectory": "neurotherapy/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
